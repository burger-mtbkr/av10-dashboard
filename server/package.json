{
  "name": "ht-status-server",
  "version": "1.0.0",
  "private": true,
  "description": "Backend server for Marantz AV10 dashboard",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "ws": "^8.18.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.2",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@types/xml2js": "^0.4.14",
    "@vitest/coverage-v8": "^4.1.2",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
